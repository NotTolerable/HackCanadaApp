# Auth server (login) — copy to .env and fill in
# Run the Auth server:  python Auth.py   (or: PORT=5001 python Auth.py)

PORT=5000
REDIRECT_URI=http://localhost:5000/callback
FRONTEND_URL=http://localhost:5173

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
FLASK_SECRET_KEY=use-a-long-random-secret

# Optional: if you use a different port, set REDIRECT_URI to match (e.g. http://localhost:5001/callback)
# Auth0 Allowed Callback URLs must contain REDIRECT_URI exactly.

DATABASE_URL=sqlite:///users.db

# Gemini (interview questions, analysis)
GEMINI_API_KEY=your_gemini_api_key

# Presage Physiology API (vitals from video) — get key at https://physiology.presagetech.com/auth/register
PRESAGE_API_KEY=your_presage_api_key
